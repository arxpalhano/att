# ArchTechTour Portal
# Para o MVP, não precisa configurar nada.
# Basta rodar: npm run dev
NODE_ENV=development

# ────────────────────────────────────────────────────────────
# AWS — upload de assets (já configurado)
# ────────────────────────────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_BUCKET_NAME=archtechtour-assets

# ────────────────────────────────────────────────────────────
# Analytics — dashboard do customizador
# Bucket onde a Lambda salva os JSONs de analytics por cliente
# ex: analytics-cache/rsdesign/latest.json
# ────────────────────────────────────────────────────────────
# ANALYTICS_S3_BUCKET=archtechtour-assets
